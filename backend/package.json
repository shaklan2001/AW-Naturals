{
  "name": "aw-naturals-api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "docker:up": "docker compose up -d",
    "predev": "sh -c 'command -v docker >/dev/null 2>&1 && docker compose up -d || echo \"predev: docker not found; start Postgres yourself and set DATABASE_URL\"'",
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "prestart": "sh -c 'command -v docker >/dev/null 2>&1 && docker compose up -d || echo \"prestart: docker not found; start Postgres yourself and set DATABASE_URL\"'",
    "start": "npm run build && node dist/server.js",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "db:seed-blogs": "tsx scripts/seed-blogs.ts",
    "db:import-fixtures": "tsx scripts/import-fixtures-from-json.ts fixtures/all-apis-and-database.json --wipe"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.5.0",
    "bcrypt": "^6.0.0",
    "cloudinary": "^2.9.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-oauth2-jwt-bearer": "^1.6.0",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.10.2",
    "prisma": "^6.5.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
