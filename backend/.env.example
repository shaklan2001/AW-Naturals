# App
NODE_ENV=development
PORT=4000

# PostgreSQL — must match backend/docker-compose.yml host port (default 5433; avoids clash with another Postgres on 5432).
DATABASE_URL="postgresql://admin:admin123@127.0.0.1:5433/mydb?schema=public"

# CORS: comma-separated origins for storefront + admin SPA
CORS_ORIGINS="http://localhost:5173,http://localhost:5174,http://127.0.0.1:5173,http://127.0.0.1:5174"

# --- Auth0 (same API audience for admin panel + storefront when using Auth0 login) ---
# When set, customer Bearer tokens from the storefront SPA are validated as Auth0 access tokens
# (RS256). First successful login creates/links a CustomerUser row via `auth0Sub` + email claim.
# AUTH0_DOMAIN="your-tenant.auth0.com"
# AUTH0_AUDIENCE="https://your-api-identifier"
# Must match the API “Identifier” in Auth0 exactly (scheme + host + path, including any trailing slash).
# If Auth0 returns “invalid audience specified for password grant exchange”, either (1) create an API
# in Auth0, set its Identifier here, and authorize your Regular Web App for that API, or (2) if your
# tenant only accepts ROPG against the built-in Management API, set AUTH0_AUDIENCE to
# https://<AUTH0_DOMAIN>/api/v2/ (same string as the Management API Identifier in Auth0 → APIs).
# Prefer a dedicated API for production instead of the Management API audience on customer tokens.
#
# --- Storefront embedded email/password (no Auth0 hosted redirect) ---
# Create a Regular Web Application in Auth0, enable "Password" grant type, authorize your API audience.
# Set these (server-only — never expose client secret in the SPA):
# AUTH0_ROPG_CLIENT_ID=""
# AUTH0_ROPG_CLIENT_SECRET=""
# AUTH0_DATABASE_REALM=Username-Password-Authentication
# Use the connection NAME (Settings tab), not the connection id from the URL (con_...).
#
# When ROPG vars are set, POST /auth/customer/login and /register use Auth0 Database + return Auth0 access tokens.
# Frontend still uses VITE_AUTH0_AUDIENCE (and domain/client id if you use them for flags only).
#
# --- Use Auth0’s built-in user store (recommended) + your Postgres profile row ---
# Passwords live only in Auth0. On first successful login the API creates a CustomerUser in YOUR database with:
#   - id: your app’s cuid (orders, profile URLs)
#   - auth0Sub: Auth0 user id (`sub` from the token)
#   - email, name: copied from token claims (and signup user_metadata.name when present)
#   - passwordHash: null (never store Auth0 passwords in Postgres)
#
# In Auth0 Dashboard: Authentication → Database → open the connection named in AUTH0_DATABASE_REALM.
#   - Do NOT use “Custom Database” / “Use my own database” unless you implement Auth0’s Login/Get User scripts.
#   - For built-in Auth0 users: use the default Username-Password-Authentication (or a new DB connection
#     with only Auth0’s user store), enable it for your Regular Web Application, and set AUTH0_DATABASE_REALM
#     to that connection’s exact name.

# --- Email/password admin (SPA login + Postman user creation) ---
# JWT_SECRET: signs tokens from POST /api/v1/auth/admin/login (min 32 chars in production).
# Non-production default is applied when unset.
# JWT_SECRET=""

# ADMIN_USER_SETUP_KEY: required header X-Admin-Setup-Key for POST /api/v1/auth/admin/register
# (create admin — API only, no UI). Non-production default: postman-admin-user-setup-key
# Production: min 12 characters.
# ADMIN_USER_SETUP_KEY=""

# Postman — import backend/postman/Admin-Create-User.postman_collection.json
#
# Admin (create user API-only; no admin sign-up in UI):
#   POST /api/v1/auth/admin/register  + header X-Admin-Setup-Key
#   Body: { "name", "email", "password" }  optional "role": "super_admin"
#   POST /api/v1/auth/admin/login — admin panel login
#
# Customer (website):
#   With Auth0 SPA: no duplicate password flow — Universal Login sends OTP if you enable Passwordless Email.
#   Legacy (no AUTH0_* on API): POST /api/v1/auth/customer/register | /customer/login (email + password JWT)

# Dev-only bearer for /api/v1/admin/* (non-production default: local-dev-admin-token)
# ADMIN_DEV_BYPASS_SECRET=""

# --- Cloudinary (admin image upload: products, blog cover, editor images, site logo) ---
# POST /api/v1/admin/uploads/image — JPEG/PNG only, max size UPLOAD_MAX_IMAGE_MB (default 5).
# CLOUDINARY_CLOUD_NAME=""
# CLOUDINARY_API_KEY=""
# CLOUDINARY_API_SECRET=""
# Optional folder prefix in your Cloudinary Media Library (default: aw-naturals)
# CLOUDINARY_UPLOAD_FOLDER="aw-naturals"
# UPLOAD_MAX_IMAGE_MB=5

# --- Razorpay (storefront checkout: POST /api/v1/payments/razorpay/*) ---
# Dashboard: https://dashboard.razorpay.com/ — use test keys in development.
# RAZORPAY_KEY_ID="rzp_test_..."
# RAZORPAY_KEY_SECRET="..."

# Production: set AUTH0_DOMAIN + AUTH0_AUDIENCE, JWT_SECRET (32+), ADMIN_USER_SETUP_KEY (12+).
# Omit ADMIN_DEV_BYPASS_SECRET in production.
# For production image uploads, set all three CLOUDINARY_* variables.
# For checkout, set RAZORPAY_KEY_ID and RAZORPAY_KEY_SECRET (live keys in production).
