generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ProductStatus {
  active
  draft
  archived
  upcoming
}

enum OrderStatus {
  pending
  processing
  shipped
  delivered
  cancelled
}

enum BlogStatus {
  published
  draft
}

enum AdminRole {
  super_admin
  admin
}

enum ContactInquiryStatus {
  pending
  in_progress
  contacted
}

model AdminUser {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String    @default("")
  passwordHash String
  role         AdminRole @default(admin)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

/// Storefront customers (sign up on website only — not admins).
model CustomerUser {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  phone        String   @default("")
  address      String   @default("")
  city         String   @default("")
  pincode      String   @default("")
  emailVerified Boolean @default(false)
  passwordHash String?
  auth0Sub     String?  @unique
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  orders Order[]
}

model Product {
  id          String        @id @default(cuid())
  name        String
  /// Compact storefront copy for list cards.
  shortDescription String?
  /// Full product narrative for detail page.
  description String
  /// Shown on the storefront; falls back to category when null.
  benefit     String?
  price       Decimal       @db.Decimal(10, 2)
  category    String
  stock       Int           @default(0)
  status      ProductStatus @default(draft)
  images      String[]
  /// Storefront "Key benefits" — bullet pointers (one string per line in admin).
  keyBenefitsPoints   String[] @default([])
  /// Ingredient tags on the product page (one per line in admin).
  ingredientsPoints   String[] @default([])
  /// Optional clinical / disclaimer copy; shown only when showClinicalNote is true.
  clinicalNote        String?  @db.Text
  showClinicalNote    Boolean  @default(false)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  orderItems OrderItem[]
}

model Order {
  id            String      @id @default(cuid())
  orderNumber   String      @unique
  customerUserId String?
  customerUser  CustomerUser? @relation(fields: [customerUserId], references: [id], onDelete: SetNull)
  customerName  String
  email         String
  phone         String
  address       String
  city          String
  pincode       String
  total         Decimal     @db.Decimal(12, 2)
  status        OrderStatus @default(pending)
  paymentMethod String
  createdAt     DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  items OrderItem[]

  @@index([customerUserId, createdAt])
}

model OrderItem {
  id          String   @id @default(cuid())
  orderId     String
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId   String?
  product     Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  /// Primary product image URL at checkout (and backfilled) so Order History survives FK issues.
  productImageSnapshot String?
  productName String
  quantity    Int
  price       Decimal  @db.Decimal(10, 2)
}

/// Homepage testimonial cards — only `published` rows appear on storefront (capped server-side).
model Testimonial {
  id           String   @id @default(cuid())
  quote        String   @db.VarChar(400)
  authorName   String   @db.VarChar(100)
  authorTitle  String   @db.VarChar(120)
  published    Boolean  @default(false)
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([published, sortOrder])
}

model Blog {
  id             String     @id @default(cuid())
  title          String
  slug           String     @unique
  author         String
  category       String
  coverImage     String
  content        String     @db.Text
  seoTitle       String
  seoDescription String
  status         BlogStatus @default(draft)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
}

/// Single-row site configuration (id is always "default").
model SiteSettings {
  id        String   @id @default("default")
  siteName  String
  siteUrl   String
  logo      String   @default("")
  tagline   String
  instagram String   @default("")
  facebook  String   @default("")
  twitter   String   @default("")
  youtube   String   @default("")
  updatedAt DateTime @updatedAt
}

/// Contact form submissions from storefront.
model ContactInquiry {
  id        String   @id @default(cuid())
  name      String
  phone     String
  email     String
  issue     String   @db.Text
  status    ContactInquiryStatus @default(pending)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
