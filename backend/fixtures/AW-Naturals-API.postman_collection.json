              "mode": "raw",
              "raw": "{\n  \"customerName\": \"JSON Tester\",\n  \"email\": \"tester@example.com\",\n  \"phone\": \"9998887776\",\n  \"address\": \"99 Test Road\",\n  \"city\": \"Hyderabad\",\n  \"pincode\": \"500001\",\n  \"paymentMethod\": \"UPI\",\n  \"items\": [\n    { \"productId\": \"play-prod-turmeric\", \"quantity\": 1 }\n  ]\n}",
