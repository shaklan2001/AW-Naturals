# Copy to `.env` — same file for local dev and production builds.
# On Netlify/hosted deploys, mirror these vars in the dashboard.

# Public API base URL (no trailing slash)
# Local backend: http://localhost:4000
# Hosted API: https://api.awnaturals.in
VITE_API_URL=https://api.awnaturals.in

# Public storefront URL (no trailing slash) — used for canonical links & sitemap.xml
# Production: https://www.awnaturals.in
VITE_SITE_URL=https://www.awnaturals.in

# Auth0-issued API tokens (embedded email/password via backend; no redirect)
# Set the same API audience as backend AUTH0_AUDIENCE.
# Backend must have AUTH0_ROPG_CLIENT_ID + AUTH0_ROPG_CLIENT_SECRET for login/register.
VITE_AUTH0_DOMAIN=your-tenant.auth0.com
VITE_AUTH0_CLIENT_ID=your-regular-web-app-client-id
VITE_AUTH0_AUDIENCE=https://your-api-identifier

# Set to 'true' to show the Coming Soon screen across the entire site
VITE_ENABLE_COMING_SOON=true
