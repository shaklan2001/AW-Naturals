# Copy to `.env` — same file for local dev and production builds.
# On Netlify/hosted deploys, mirror these vars in the dashboard.

# Backend API base URL (no trailing slash)
# Local backend: http://localhost:4000
# Hosted API: https://api.awnaturals.in
VITE_API_URL=https://api.awnaturals.in

# Image uploads (JPEG/PNG) use Cloudinary on the API — set CLOUDINARY_* in backend/.env (see backend/.env.example).

# Create the first admin via Postman: backend/postman/Admin-Create-User.postman_collection.json
